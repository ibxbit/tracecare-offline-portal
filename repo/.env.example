# Example environment file for TraceCare Offline Compliance Portal
# Copy to `.env` and edit values as needed

# --- Security ---
SECRET_KEY=
ENCRYPTION_KEY=

# --- Database ---
DATABASE_URL=postgresql://tracecare:tracecare@localhost:5432/tracecare

# --- Auth ---
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Notification ---
NOTIFICATION_RETRY_SCHEDULE_MINUTES=1,5,15,60

# --- Other settings ---
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=12
ATTACHMENTS_DIR=./uploads/catalog
REVIEW_IMAGES_DIR=./uploads/reviews
